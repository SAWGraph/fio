#################################################################
#    Classes
#################################################################

###  http://w3id.org/fio/v1/fio#Industry
<http://w3id.org/fio/v1/fio#Industry> rdf:type owl:Class .


###  http://w3id.org/fio/v1/naics#NAICS-Industry
<http://w3id.org/fio/v1/naics#NAICS-Industry> rdf:type owl:Class ;
