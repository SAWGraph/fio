        <rdfs:domain rdf:resource="http://w3id.org/fio/v1/epa-frs#FRS-Facility"/>
        <rdfs:range rdf:resource="http://w3id.org/fio/v1/epa-frs#MonitoringRecord"/>
        <rdfs:label>has monitoring record</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/fio/v1/epa-frs#hasRecord -->


    <owl:ObjectProperty rdf:about="http://w3id.org/fio/v1/epa-frs#hasRecord">
