        <rdfs:range rdf:resource="http://w3id.org/fio/v1/epa-frs#SupplementalRecord"/>
        <rdfs:label>has supplemental record</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/fio/v1/epa-frs#ofFacilityType -->


    <owl:ObjectProperty rdf:about="http://w3id.org/fio/v1/epa-frs#ofFacilityType">
