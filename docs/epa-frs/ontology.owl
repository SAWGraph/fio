    </owl:Class>
    


    <!-- http://w3id.org/fio/v1/epa-frs#EnvironmentalInterestByRecordType -->


    <owl:Class rdf:about="http://w3id.org/fio/v1/epa-frs#EnvironmentalInterestByRecordType">
        <rdfs:subClassOf rdf:resource="http://w3id.org/fio/v1/epa-frs#EnvironmentalInterestType"/>
    </owl:Class>
    


    <!-- http://w3id.org/fio/v1/epa-frs#EnvironmentalInterestType -->


    <owl:Class rdf:about="http://w3id.org/fio/v1/epa-frs#EnvironmentalInterestType">
        <terms:description>The environmental permit or regulatory program type that applies to the facility site</terms:description>
        <rdfs:label>Environmental Interest Type</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/fio/v1/epa-frs#FRS-Facility -->


    <owl:Class rdf:about="http://w3id.org/fio/v1/epa-frs#FRS-Facility">
        <rdfs:subClassOf rdf:resource="http://w3id.org/fio/v1/fio#Facility"/>
        <terms:description>Facility from EPA Facility Registry Service</terms:description>
        <rdfs:label>FRS Facility</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/fio/v1/epa-frs#FacilityType -->


    <owl:Class rdf:about="http://w3id.org/fio/v1/epa-frs#FacilityType">
        <terms:description>Type of Facility as defined by EPA FRS facility type controlled vocabulary</terms:description>
        <rdfs:label>Facility Type</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/fio/v1/epa-frs#MonitoringRecord -->


    <owl:Class rdf:about="http://w3id.org/fio/v1/epa-frs#MonitoringRecord">
        <rdfs:subClassOf rdf:resource="http://w3id.org/fio/v1/epa-frs#Record"/>
        <terms:description>Monitoring Record for a facility</terms:description>
        <rdfs:label>Facility Monitoring Record</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/fio/v1/epa-frs#ProgramInformationSystem -->


    <owl:Class rdf:about="http://w3id.org/fio/v1/epa-frs#ProgramInformationSystem">
        <terms:description>An Information System maintained for an environmental program</terms:description>
        <rdfs:label>Program Information System</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/fio/v1/epa-frs#Record -->


    <owl:Class rdf:about="http://w3id.org/fio/v1/epa-frs#Record">
        <rdfs:label>Facility Record</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/fio/v1/epa-frs#SupplementalRecord -->


    <owl:Class rdf:about="http://w3id.org/fio/v1/epa-frs#SupplementalRecord">
        <rdfs:subClassOf rdf:resource="http://w3id.org/fio/v1/epa-frs#Record"/>
        <terms:description>Supplemental Record that relates to a facility but primarily identifies something other than the facility itself (e.g. permit, license, incident, enforcement action records) </terms:description>
        <rdfs:label>Facility Supplemental Record</rdfs:label>
    </owl:Class>
    


