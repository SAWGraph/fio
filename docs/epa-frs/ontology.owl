    <!-- http://w3id.org/fio/v1/epa-frs#hasEnvironmentalInterest -->


    <owl:ObjectProperty rdf:about="http://w3id.org/fio/v1/epa-frs#hasEnvironmentalInterest">
        <rdfs:range rdf:resource="http://w3id.org/fio/v1/epa-frs#EnvironmentalInterestType"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://w3id.org/fio/v1/epa-frs#hasRecord"/>
            <rdf:Description rdf:about="http://w3id.org/fio/v1/epa-frs#ofInterestType"/>
        </owl:propertyChainAxiom>
        <rdfs:label>in program type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/fio/v1/epa-frs#hasMonitoringRecord -->


    <owl:ObjectProperty rdf:about="http://w3id.org/fio/v1/epa-frs#hasMonitoringRecord">
