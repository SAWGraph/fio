        <rdfs:range rdf:resource="http://w3id.org/fio/v1/epa-frs#FacilityType"/>
        <rdfs:label>of facility type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/fio/v1/epa-frs#ofInterestType -->


    <owl:ObjectProperty rdf:about="http://w3id.org/fio/v1/epa-frs#ofInterestType">
        <rdfs:range rdf:resource="http://w3id.org/fio/v1/epa-frs#EnvironmentalInterestType"/>
        <rdfs:label>of program category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/fio/v1/epa-frs#ofPrimaryIndustry -->


    <owl:ObjectProperty rdf:about="http://w3id.org/fio/v1/epa-frs#ofPrimaryIndustry">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/fio/v1/fio#ofIndustry"/>
        <rdfs:label>of Primary Industry</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/fio/v1/epa-frs#ofSecondaryIndustry -->


    <owl:ObjectProperty rdf:about="http://w3id.org/fio/v1/epa-frs#ofSecondaryIndustry">
        <rdfs:subPropertyOf rdf:resource="http://w3id.org/fio/v1/fio#ofIndustry"/>
        <rdfs:label>of Secondary Industry</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://w3id.org/fio/v1/fio#ofIndustry -->


    <owl:ObjectProperty rdf:about="http://w3id.org/fio/v1/fio#ofIndustry">
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://w3id.org/fio/v1/epa-frs#hasRecord"/>
            <rdf:Description rdf:about="http://w3id.org/fio/v1/epa-frs#ofPrimaryIndustry"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://w3id.org/fio/v1/epa-frs#hasRecord"/>
            <rdf:Description rdf:about="http://w3id.org/fio/v1/epa-frs#ofSecondaryIndustry"/>
        </owl:propertyChainAxiom>
    </owl:ObjectProperty>
    


