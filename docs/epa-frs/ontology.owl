    <!-- http://w3id.org/fio/v1/epa-frs#Agency -->


    <owl:Class rdf:about="http://w3id.org/fio/v1/epa-frs#Agency">
        <rdfs:subClassOf rdf:resource="http://w3id.org/fio/v1/fio#Organization"/>
        <terms:description>Federal Agency as identified in EPA Facility Registry Service</terms:description>
        <rdfs:label>Agency</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/fio/v1/epa-frs#EPA-PFAS-Facility -->


    <owl:Class rdf:about="http://w3id.org/fio/v1/epa-frs#EPA-PFAS-Facility">
        <rdfs:subClassOf rdf:resource="http://w3id.org/fio/v1/epa-frs#FRS-Facility"/>
        <terms:description>Facility identified as potentially handling PFAS in EPA PFAS Analytic tools based on industry. </terms:description>
        <rdfs:label>EPA PFAS Facility</rdfs:label>
    </owl:Class>
    


    <!-- http://w3id.org/fio/v1/epa-frs#EnvironmentalInterestByProgram -->


    <owl:Class rdf:about="http://w3id.org/fio/v1/epa-frs#EnvironmentalInterestByProgram">
