@prefix fio: <http://w3id.org/fio/v1/fio#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix naics: <http://w3id.org/fio/v1/naics#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://w3id.org/fio/naics#> rdf:type owl:Ontology ;
                              owl:versionIRI naics: ;
                              dcterms:created "2024-03-06"@en-us ;
                              dcterms:creator <http://orcid.org/0000-0002-5331-5052> ,
                                            <https://orcid.org/0000-0003-3271-6700> ;
                              dcterms:description "North American Industry Classification Ontology developed as part of the SAWGraph project."@en-us ;
                              dcterms:issued "2024-03-06"^^xsd:date ;
                              dcterms:modified "2024-03-06"^^xsd:date ;
                              dcterms:publisher <http://spatialai.org> ;
                              dcterms:title "North American Industry Classification System Ontology"@en-us ;
                              owl:versionInfo "1"@en-us .

### Classes

naics:NAICS-Industry rdf:type owl:Class ;
    rdfs:subClassOf fio:Industry.

naics:NAICS-IndustryCode rdf:type owl:Class ;
                        rdfs:subClassOf naics:NAICS-Industry.

naics:NAICS-IndustryGroup rdf:type owl:Class ;
                        rdfs:subClassOf naics:NAICS-Industry .

naics:NAICS-IndustrySector rdf:type owl:Class ;
                 rdfs:subClassOf naics:NAICS-Industry.

naics:NAICS-IndustrySubsector rdf:type owl:Class ;
                    rdfs:subClassOf naics:NAICS-Industry .


